# ============================================
# Avalon Pedia - Environment Variables Template
# ============================================

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ============================================
# Firebase Configuration
# ============================================
# Get these from Firebase Console > Project Settings

FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_bucket.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Firebase Service Account (for admin SDK)
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com

# ============================================
# Discord Bot Configuration
# ============================================
# Create app at https://discord.com/developers/applications

DISCORD_BOT_TOKEN=xoxb_your_token_here
DISCORD_CLIENT_ID=123456789
DISCORD_GUILD_ID=987654321  # Optional, for testing/development

# ============================================
# Line Bot Configuration
# ============================================
# Create channel at https://developers.line.biz/

LINE_BOT_CHANNEL_ACCESS_TOKEN=your_line_access_token
LINE_BOT_CHANNEL_SECRET=your_line_channel_secret
LINE_GROUP_ID=your_group_id  # Optional
LINE_USER_ID=your_user_id    # Optional

# LINE Notify OAuth (for push notifications via LINE Notify API)
# Register at https://notify-bot.line.me/my/
LINE_NOTIFY_CLIENT_ID=your_line_notify_client_id
LINE_NOTIFY_CLIENT_SECRET=your_line_notify_client_secret

# ============================================
# Game Configuration
# ============================================
MAX_PLAYERS=10
MIN_PLAYERS=5
VOTE_TIMEOUT=30000        # 30 seconds
QUEST_TIMEOUT=60000       # 1 minute
DISCUSSION_TIMEOUT=120000 # 2 minutes

# ============================================
# Frontend Configuration
# ============================================
VITE_API_URL=http://localhost:3001
REACT_APP_ENV=development

# ============================================
# CORS & Security
# ============================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://your-domain.com
ALLOWED_DOMAINS=localhost:5173,localhost:3000,your-domain.com

# ============================================
# Session Configuration
# ============================================
SESSION_SECRET=your_random_secret_key_here_generate_with_node
SESSION_EXPIRY=86400000  # 24 hours in milliseconds

# ============================================
# Database (Optional)
# ============================================
# DATABASE_URL=postgresql://user:password@localhost:5432/avalon
# REDIS_URL=redis://localhost:6379

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=info           # debug, info, warn, error
LOG_FORMAT=json          # json, text
SENTRY_DSN=             # Error tracking (optional)

# ============================================
# Email Configuration (Optional)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# ADMIN_EMAIL=admin@your-domain.com
