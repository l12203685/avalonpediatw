# ── Firebase Configuration ───────────────────────────────────
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Firebase Admin Service Account JSON (base64 or raw JSON string)
FIREBASE_SERVICE_ACCOUNT_JSON={}

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# ── Auth / Security ──────────────────────────────────────────
# Custom JWT secret for Discord/Line OAuth tokens.
# REQUIRED — server will refuse to start if unset.
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex') |> console.log"
# or: openssl rand -hex 32
# Minimum 32 characters recommended.
JWT_SECRET=

# Admin API secret for /api/ai/selfplay endpoint
ADMIN_SECRET=change-me-in-production

# ── Discord OAuth ────────────────────────────────────────────
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_BOT_TOKEN=your_discord_bot_token

# ── Line Bot ─────────────────────────────────────────────────
LINE_BOT_CHANNEL_ACCESS_TOKEN=your_line_bot_access_token
LINE_BOT_CHANNEL_SECRET=your_line_bot_channel_secret

# ── Line OAuth (for web login) ────────────────────────────────
LINE_CHANNEL_ID=your_line_channel_id
LINE_CHANNEL_SECRET=your_line_channel_secret   # same secret reused for OAuth

# ── Line Notify OAuth ─────────────────────────────────────────
LINE_NOTIFY_CLIENT_ID=your_line_notify_client_id
LINE_NOTIFY_CLIENT_SECRET=your_line_notify_client_secret

# ── CORS / Server ────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Frontend URL (used for OAuth redirect URIs)
FRONTEND_URL=http://localhost:5173
