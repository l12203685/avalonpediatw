# Dependencies / lockfile caches
node_modules
packages/*/node_modules
.pnpm-store

# Build outputs (re-built in container)
dist
packages/*/dist
packages/*/.turbo
.turbo
build
out
.next

# Environment / credentials — NEVER bake into image
.env
.env.*
!.env.example
firebase-service-account.json
packages/*/firebase-service-account.json

# VCS / CI
.git
.github
.gitignore
.gitattributes

# IDE / OS
.vscode
.idea
.DS_Store
Thumbs.db
*.swp

# Docs / legacy (not needed at runtime)
docs
archive
analysis
apps
content
assets
*.md
!README.md

# Test / coverage artifacts
coverage
.nyc_output
packages/*/coverage
vitest.config.d.ts
vitest.config.d.ts.map
vitest.config.js
vitest.config.js.map

# Local dev volumes
postgres_data
redis_data

# Generator scripts (not needed in runtime)
packages/server/generate_cache.py
packages/server/sheets_cache.json

# Web package — Cloudflare Pages 獨立部署，不進 server image
packages/web

# Firebase / Supabase local dev files
firebase.json
database.rules.json
firestore.rules
supabase

# Logs
*.log
logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python venv / cache (if any)
__pycache__
*.pyc
.venv
venv
