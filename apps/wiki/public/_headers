# Cloudflare Pages — HTTP headers for avalonpediatw.com
# Docs: https://developers.cloudflare.com/pages/platform/headers/
# This file is copied verbatim into the build output by Astro (files in
# public/ pass through untouched).

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Long-cache immutable assets (Astro fingerprints filenames)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML: short cache, always revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# YAML content files (if exposed): revalidate frequently
/data/*.yaml
  Cache-Control: public, max-age=300
