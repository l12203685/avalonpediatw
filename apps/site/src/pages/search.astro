---
import BaseLayout from '../layouts/BaseLayout.astro';
import Search from 'astro-pagefind/components/Search';
---
<BaseLayout title="搜尋">
  <h1 class="text-3xl font-bold mb-6">全站搜尋</h1>
  <Search id="search" className="pagefind-ui" uiOptions={{ showImages: false, translations: { placeholder: '搜尋角色、規則、策略…', clear_search: '清除', load_more: '載入更多', search_label: '搜尋', filters_label: '篩選', zero_results: '找不到 [SEARCH_TERM] 的結果', many_results: '找到 [COUNT] 個結果', one_result: '找到 [COUNT] 個結果', alt_search: '找不到 [SEARCH_TERM] 的結果。正在顯示 [DIFFERENT_TERM] 的結果', search_suggestion: '找不到 [SEARCH_TERM] 的結果。試試：', searching: '搜尋 [SEARCH_TERM] 中…' } }} />
</BaseLayout>
